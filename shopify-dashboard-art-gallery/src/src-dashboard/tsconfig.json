{
    "compilerOptions": {
      "target": "esnext",
      "module": "commonjs",
      "jsx": "react",
      "strict": false,
        "noImplicitAny": false,
        "suppressImplicitAnyIndexErrors": true,
      "allowImportingTsExtensions": true,
        "noEmit": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": ["./*"],
    "exclude": ["node_modules"]
  }
